// Unity 프로젝트 루트의 .zed/tasks.json 에 넣으세요.
// Zed에서 task: spawn (기본 alt-shift-t / ctrl-shift-p → "task spawn") 으로 실행합니다.
[
  {
    "label": "Unity ▶ Play",
    "command": "curl -s http://localhost:17890/play",
    "reveal": "never",
    "hide": "always"
  },
  {
    "label": "Unity ■ Stop",
    "command": "curl -s http://localhost:17890/stop",
    "reveal": "never",
    "hide": "always"
  },
  {
    "label": "Unity ⏸ Pause 토글",
    "command": "curl -s http://localhost:17890/pause",
    "reveal": "never",
    "hide": "always"
  },
  {
    "label": "Unity ↻ Refresh + Compile",
    "command": "curl -s http://localhost:17890/compile",
    "reveal": "never",
    "hide": "always"
  },
  {
    "label": "Unity ● Status",
    "command": "curl -s http://localhost:17890/status",
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "Unity ☰ Console 로그",
    "command": "curl -s http://localhost:17890/logs",
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "Unity ☰ 로그 실시간 감시 (Windows)",
    "command": "powershell -NoProfile -Command \"while($true){ Clear-Host; curl.exe -s http://localhost:17890/logs; Start-Sleep -Seconds 2 }\"",
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "Unity ✓ Test Runner 열기",
    "command": "curl -s \"http://localhost:17890/menu?path=Window/General/Test%20Runner\"",
    "reveal": "never",
    "hide": "always"
  }
]
